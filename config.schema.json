{
  "pluginAlias": "PhilipsAirPlusPlatform",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "headerDisplay": "Homebridge Plugin for Philips Air+ Smart Heater",
  "footerDisplay": "The plugin uses a library (phipsair) based on python3. So these requirements need to be installed first.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "PhilipsAirPlusPlatform",
        "description": "Name for the log."
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "active": {
              "title": "Active",
              "type": "boolean",
              "description": "If enabled, the device will be exposed to HomeKit."
            },
            "debug": {
              "title": "Debug",
              "type": "boolean",
              "description": "Enables additional output (debug) in the log."
            },                  
            "name": {
              "title": "Name",
              "type": "string",
              "required": true,
              "description": "Device display name",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            },
            "deviceId": {
              "title": "Device Id",
              "type": "string",
              "required": true,
              "description": "Device unique id",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            },            
            "ip_address": {
              "title": "IP Address",
              "type": "string",
              "required": true,
              "format": "ipv4",
              "placeholder": "10.0.1.16",
              "description": "IP address of your device.",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            },
            "port": {
              "title": "Port",
              "type": "integer",
              "placeholder": 5683,
              "description": "Port of your device.",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            },
            "model": {
              "title": "Device Model",
              "type": "string",
              "oneOf": [
                { "title": "Auto-detect", "enum": [""] },
                { "title": "CX5120", "enum": ["CX5120"] },
                { "title": "CX3120", "enum": ["CX3120"] }
              ],
              "default": "",
              "description": "Device model. Auto-detect will determine the model from the device response.",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            },
            "enableBacklight": {
              "title": "Enable Backlight Control",
              "type": "boolean",
              "default": true,
              "description": "Enable the backlight control service. Disable this for models that don't support it (e.g., CX3120).",
              "condition": {
                "functionBody": "try { return model.devices[arrayIndices[0]].active } catch(e){ return false }"
              }
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "title": "Configuration",
      "type": "fieldset",
      "items": [
        "name"
      ]      
    },
    {
      "key": "devices",
      "title": "Devices",
      "expandable": true,
      "expanded": true,
      "orderable": false,
      "add": "Add Device",
      "type": "array",
      "items": [
        {
          "type": "fieldset",
          "items": [
            "devices[].active",
            "devices[].debug",
            "devices[].deviceId",
            "devices[].name",
            "devices[].ip_address",
            "devices[].port",
            "devices[].model",
            "devices[].enableBacklight"
          ]
        }
      ]
    }
  ]
}